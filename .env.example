# Polymarket Bot Configuration - AcropolisBot

# ===== WALLET =====
PRIVATE_KEY=0x_your_private_key_here
FUNDER_ADDRESS=    # Required for proxy wallets (Magic/social login)
SIGNATURE_TYPE=0   # 0=EOA/MetaMask, 1=Magic/proxy

# ===== MODE =====
PAPER_TRADE=true   # Set to false for live trading

# ===== MARKETS =====
# Comma-separated list of markets to trade (leave empty for all)
# Options: BTC_5M, BTC_15M, ETH_5M, ETH_15M, SOL_5M, SOL_15M
ACTIVE_MARKETS=BTC_5M,ETH_5M,SOL_5M

# ===== STRATEGIES =====
# Enable/disable individual strategies
ENABLE_ARBITRAGE=true       # Micro-arbitrage (PRIMARY strategy)
ENABLE_STREAK=true          # Streak reversal
ENABLE_COPYTRADE=false      # Copytrade
ENABLE_SELECTIVE=false      # Selective copytrade

# ===== ARBITRAGE SETTINGS =====
ARB_THRESHOLD=0.98          # Buy when YES+NO < this (0.98 = 2% edge)
ARB_MIN_EDGE_PCT=0.5        # Minimum edge percentage to trade (0.5%)
ARB_MAX_EXPOSURE=100        # Max concurrent arbitrage positions (USD)
ARB_CHECK_INTERVAL=0.1      # Check prices every N seconds (100ms)
ARB_MIN_BET=5               # Minimum bet size for arbitrage

# ===== STREAK SETTINGS =====
STREAK_TRIGGER=4            # Bet after N consecutive same outcomes
STREAK_MIN_REVERSAL_RATE=0.60   # Only bet if historical reversal >= this

# ===== COPYTRADE SETTINGS =====
COPY_WALLETS=               # Comma-separated wallet addresses
COPY_POLL_INTERVAL=1.5      # Poll wallets every N seconds
SELECTIVE_FILTER=false      # Enable quality filters
SELECTIVE_MAX_DELAY_MS=20000
SELECTIVE_MIN_FILL_PRICE=0.55
SELECTIVE_MAX_FILL_PRICE=0.80
SELECTIVE_MAX_SPREAD=0.025

# ===== BANKROLL & COMPOUNDING =====
INITIAL_BANKROLL=100.0      # Starting bankroll (USD)
RISK_LEVEL=moderate         # conservative, moderate, aggressive
KELLY_FRACTION=0.25         # Kelly criterion fraction (0.25 = quarter Kelly)
AUTO_COMPOUND=true          # Auto-increase bet size as bankroll grows
MIN_BET=5                   # Minimum bet size (USD)
MAX_BET=100                 # Maximum bet size (USD)

# ===== RISK MANAGEMENT =====
MAX_DAILY_BETS=100          # Max bets per day (across all strategies)
MAX_DAILY_LOSS=100          # Stop trading if daily loss exceeds this
DRAWDOWN_THRESHOLD=0.20     # Pause if bankroll drops 20% from peak
CIRCUIT_BREAKER_LOSSES=5    # Pause after N consecutive losses
COOLDOWN_MINUTES=30         # Cooldown period after circuit breaker

# ===== TIMING =====
ENTRY_SECONDS_BEFORE=30     # Enter N seconds before window opens (streak)
TIMEZONE=America/New_York

# ===== API SETTINGS =====
USE_WEBSOCKET=true          # WebSocket for real-time orderbook
REST_TIMEOUT=3
REST_RETRIES=2
WS_RECONNECT_DELAY=5

# ===== POLYGONSCAN =====
POLYGONSCAN_API_KEY=        # For on-chain trade verification

# ===== PAPER TRADING (Independent Mode) =====
PAPER_INITIAL_BANKROLL=1000.0   # Virtual starting bankroll for paper trading
PAPER_LOG_FILE=paper_trades.json  # File to store paper trade history

# ===== WEB GUI =====
WEB_PORT=8080
WEB_HOST=0.0.0.0
WEB_SECRET_KEY=change_me_in_production   # For session management
