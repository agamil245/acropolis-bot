# AcropolisBot — Environment Config
# Only secrets and infrastructure settings live here.
# Everything else (strategies, markets, risk, etc.) is configured from the dashboard.

# ===== WALLET (required) =====
PRIVATE_KEY=0x_your_private_key_here
FUNDER_ADDRESS=              # Required for proxy wallets (Magic/social login)
SIGNATURE_TYPE=0             # 0=EOA/MetaMask, 1=Magic/proxy

# ===== BINANCE (required for latency arb) =====
BINANCE_API_KEY=             # Optional: for authenticated streams (higher rate limits)

# ===== POLYGONSCAN =====
POLYGONSCAN_API_KEY=         # Optional: for on-chain trade verification

# ===== WEB GUI =====
WEB_PORT=8080
WEB_HOST=0.0.0.0
WEB_SECRET_KEY=change_me_in_production

# ===== INITIAL BANKROLL =====
INITIAL_BANKROLL=100.0       # Starting bankroll — after this, manage from dashboard
